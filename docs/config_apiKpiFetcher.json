{
  "version": "1.0.0",

  "BaseScriptPaths": {
    "MainLoader": "https://kvcode.github.io/cognosApiKpiFetcher/apiKpiFetcher.js",
    "MainCSS": "https://kvcode.github.io/cognosApiKpiFetcher/styleApiKpiFetcher.css",
    "ListRenderer": "https://kvcode.github.io/cognosApiKpiFetcher/listRenderer.js",
    "ChartRenderer": "https://kvcode.github.io/cognosApiKpiFetcher/chartRenderer.js"
  },

  "locale": "auto",
  "kpiDataStore": "FFP_Dimensions",
  "tokenStorageKey": "ffp_kpi_oauth_token",

  "callbackUrl": "https://cognosanalytics-dev.vw.vwg/cognos4/samples/javascript/apiFetcher/callback.html",

  "oauthPreset": {
    "authorizeUrl": "https://idp.cloud.vwgroup.com/auth/realms/kums-mfa/protocol/openid-connect/auth",
    "tokenUrl": "https://idp.cloud.vwgroup.com/auth/realms/kums-mfa/protocol/openid-connect/token",
    "clientId": "idp-1074ff7b-de41-40a6-80ae-dbae5e4797f8-ffp-api-clients",
    "scope": "openid"
  },

  "api": {
    "baseUrlTemplate": "https://ffp-admin-docker-fe.sqlab-app-ffp.dapc{env}.ocp.vwgroup.com",
    "environments": {
      "PROD": "",
      "QS": "-q",
      "DEV": "-d"
    },
    "defaultEnvironment": "QS",
    "acceptHeader": "application/prs.hal-forms+json"
  },

  "aggregations": [
    { "value": "production_month", "labels": { "en": "Production Month", "de": "Produktionsmonat" } },
    { "value": "brand_2_digit", "labels": { "en": "Brand", "de": "Marke" } },
    { "value": "production_year", "labels": { "en": "Production Year", "de": "Produktionsjahr" } },
    { "value": "modell_year", "labels": { "en": "Model Year", "de": "Modelljahr" } },
    { "value": "car_plant", "labels": { "en": "Plant", "de": "Werk" } },
    { "value": "iso3_del", "labels": { "en": "Delivery Country", "de": "Lieferland" } }
  ],

  "dataMap": [
    { "columnName": "MIS", "apiParam": "mis", "role": "mis", "labels": { "en": "MIS", "de": "MIS" } },
    { "columnName": "MARKE_2", "apiParam": "brand_2_digit", "labels": { "en": "Brand", "de": "Marke" } },
    { "columnName": "ISO3_LFG", "apiParam": "iso3_del", "labels": { "en": "Country", "de": "Land" } },
    { "columnName": "MODELL_JAHR", "apiParam": "modell_year", "labels": { "en": "Model Year", "de": "Modelljahr" } },
    { "columnName": "VMODEL_6", "apiParam": "model_6digit", "labels": { "en": "Model", "de": "Modell" } }
  ],

  "buttons": [
    {
      "id": "sf1000",
      "labels": { "en": "Load SF1000 KPI", "de": "SF1000 KPI laden" },
      "endpoint": "/jwt/search-service/damage_cases_per_1000/",
      "kpiColumnLabel": { "en": "SF1000", "de": "SF1000" },
      "deltaThresholds": { "good": 0.0, "warn": 0.1, "critical": 0.5 }
    }
  ]
}
